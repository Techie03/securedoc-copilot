# ==========================================
# SecureDoc Copilot - Environment Configuration
# ==========================================

# ------------------------------------------
# NVIDIA NIM (Exclusive AI Provider)
# ------------------------------------------
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3

# ------------------------------------------
# Authentication (JWT)
# ------------------------------------------
JWT_SECRET=generaterandomsecretkeyhereforminimalsecurity
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------
# Relational Database (Supabase PostgreSQL)
# ------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/securedoc_db

# ------------------------------------------
# Vector Database (Qdrant)
# ------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=securedoc_copilot_chunks

# ------------------------------------------
# File Storage (Supabase Storage)
# ------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=securedoc-files

# ------------------------------------------
# Queue/Cache (Redis)
# ------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------
# Frontend
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
